# CortexReel Docker Environment Configuration
# CRITICAL: Copy this to .env.docker and replace placeholder values
# NEVER commit .env.docker to version control

# Application Settings
NODE_ENV=production
PORT=3001
APP_NAME=CortexReel

# Database Configuration
MONGODB_URI=mongodb://cortexreel:cortexreel_mongo_2024!@mongodb:27017/cortexreel?authSource=admin

# Redis Configuration
REDIS_URL=redis://:cortexreel_redis_2024!@redis:6379

# Weaviate Configuration
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_API_KEY=cortexreel-weaviate-key-2024

# MinIO Configuration
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=cortexreel
MINIO_SECRET_KEY=cortexreel_minio_2024!
MINIO_USE_SSL=false

# AI API Keys (REPLACE WITH YOUR ACTUAL KEYS)
GEMINI_API_KEY=your_actual_gemini_api_key_here
OPENAI_API_KEY=your_actual_openai_api_key_here
CLAUDE_API_KEY=your_actual_claude_api_key_here

# Security Settings
JWT_SECRET=cortexreel_super_secret_jwt_key_2024_change_in_production
SESSION_SECRET=cortexreel_session_secret_key_2024_change_in_production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload Settings
MAX_FILE_SIZE=52428800
UPLOAD_PATH=/app/uploads

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Health Check
HEALTH_CHECK_INTERVAL=30000

# CORS Settings
CORS_ORIGIN=https://localhost,https://cortexreel.local 